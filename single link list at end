#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
};

int main()
{
    struct node *head = NULL, *newnode, *temp;

    head = (struct node *)malloc(sizeof(struct node));
    head->data = 10;

    head->next = (struct node *)malloc(sizeof(struct node));
    head->next->data = 20;
    head->next->next = NULL;

    newnode = (struct node *)malloc(sizeof(struct node));
    newnode->data = 30;
    newnode->next = NULL;

    temp = head;

    while(temp->next != NULL)
    {
        temp = temp->next;
    }

    temp->next = newnode;

    temp = head;

    printf("Linked List:\n");
    while(temp != NULL)
    {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }
    printf("NULL");

    return 0;
}
